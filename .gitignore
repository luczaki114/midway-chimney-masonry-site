# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# skills (installed via skills-lock.json, like node_modules)
# drill down through each level so git sees the proprietary skill exception
/.agents/*
!/.agents/skills/
/.agents/skills/*
!/.agents/skills/midway-chimney-masonry-design/

# local Claude Code settings and skill cache
.claude/

# Windows
Thumbs.db
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# playwright
.playwright-mcp/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
